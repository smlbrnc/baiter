# =============================================================================
# Senaryoya göre zorunluluk (docs/api ile uyumlu)
# -----------------------------------------------------------------------------
# • Sadece Gamma (metadata, public): hiçbir Polymarket sırrı gerekmez; yalnızca
#   isteğe bağlı URL override kullanılabilir.
# • CLOB public (orderbook, fiyat, /time): sırra gerek yok.
# • CLOB L2 (emir, iptal, trades, heartbeat, User WebSocket): aşağıdaki L2
#   değişkenleri zorunludur (REST’te 5 header; imza ve timestamp kodda üretilir).
# • API anahtarı türetme / L1 (/auth/*) veya EIP-712 emir imzası: private key
#   ve zincir sabitleri gerekir.
# =============================================================================

# --- Gamma API (read-only, auth yok; docs/api/polymarket-gamma.md) ----------
# Staging yok; varsayılan production. İhtiyaç yoksa yorumda bırakın.
# GAMMA_BASE_URL=https://gamma-api.polymarket.com

# --- CLOB REST / WS tabanı (docs/api/polymarket-clob.md) ---------------------
# Production varsayılan. Staging testi için değiştirin.
# CLOB_BASE_URL=https://clob.polymarket.com
# CLOB_WS_BASE=wss://ws-subscriptions-clob.polymarket.com/ws
# Sports WS (ayrı host): wss://sports-api.polymarket.com/ws

# --- CLOB L2 — kimlik doğrulama (authenticated endpoint + User WS auth alanı) -
# Response’taki apiKey / secret / passphrase ile aynı; kayıp halinde yeniden
# api-key oluşturmanız gerekir.
# POLY_ADDRESS=
# POLY_API_KEY=
# POLY_PASSPHRASE=
# POLY_SECRET=

# --- CLOB L1 — private key (API credential oluşturma/derive veya EIP-712 emir) -
# POLYGON_PRIVATE_KEY=
# L1 header POLY_NONCE için (varsayılan 0; docs’ta belirtildiği gibi)
# POLY_AUTH_NONCE=0

# --- Zincir / EIP-712 (Polygon mainnet; ClobAuthDomain ve order domain) -------
# POLYGON_CHAIN_ID=137

# --- Emir oluşturma (signatureType & funder; docs “Signature Types & Funder”) -
# 0=EOA, 1=POLY_PROXY, 2=GNOSIS_SAFE — Polymarket.com cüzdan tipine göre.
# POLY_SIGNATURE_TYPE=0
# Fonların tutulduğu adres; çoğu durumda POLY_ADDRESS ile aynı, proxy/Safe’te farklı olabilir.
# POLY_FUNDER=

# --- Uygulama (Rust sunucusu) ------------------------------------------------
# PORT=3000
# RUST_LOG=info
