# Baiter Pro — runtime environment (see docs/bot-platform-mimari.md §18)
# Copy to `.env` and fill in (Live mod zorunlu alanlar).

# ---- Runtime paths --------------------------------------------------------
PORT=3000
DB_PATH=./data/baiter.db
BOT_BINARY=./target/release/bot
HEARTBEAT_DIR=./data/heartbeat

# ---- Polymarket endpoints -------------------------------------------------
# CLOB V2 (28 Nisan 2026 cutover ile `clob.polymarket.com` V2'ye geçti).
# `clob-v2.polymarket.com` deprecated test hostudur ve 301 redirect ile
# `clob.polymarket.com`'a yönlenir; reqwest POST→GET dönüştürdüğü için
# /heartbeats /order vb. uçlarda 405 alınır → asla kullanma.
GAMMA_BASE_URL=https://gamma-api.polymarket.com
CLOB_BASE_URL=https://clob.polymarket.com
CLOB_WS_BASE=wss://ws-subscriptions-clob.polymarket.com/ws

POLYGON_CHAIN_ID=137

# ---- RTDS (Polymarket real-time-data; Chainlink feed) --------------------
# docs/signal-lightplan.md §3-4. Auth-siz public WS, 1 tick/sn.
RTDS_WS_URL=wss://ws-live-data.polymarket.com
# Bu süre kadar tick atlarsa WS sağlıklı görünse bile force reconnect
# (zombie bağlantı koruması).
RTDS_STALE_THRESHOLD_MS=30000
# Reconnect exponential backoff üst sınırı (1s → 2s → 4s → … → max).
RTDS_RECONNECT_MAX_BACKOFF_MS=60000

# ---- Credentials notu ----------------------------------------------------
# Tüm credential'lar DB tablolarından okunur (`bot_credentials` →
# `global_credentials` chain). Frontend Settings sayfasından L1 EIP-712 derive
# ile yazılır; .env üzerinden okuma yok.
#
# V2 `builder` alanı sabit (`config::BUILDER_CODE_HEX`); per-bot override yok.
# Builder programı: https://docs.polymarket.com/developers/builder-program

# ---- Logging --------------------------------------------------------------
RUST_LOG=info,hyper=warn,sqlx=warn
